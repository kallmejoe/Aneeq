{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "noEmit": true,
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "apps/*/.nuxt",
    "apps/*/.output"
  ]
}
